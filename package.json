{
  "name": "viewport-lock",
  "version": "0.0.1",
  "description": "Keep fixed headers and footers in place when the mobile virtual keyboard opens",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "bun": "./src/react.ts",
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "files": ["src", "dist"],
  "scripts": {
    "build": "rm -rf dist && bun build ./src/*.ts --outdir ./dist --format esm --splitting --external react && bun run build:types",
    "build:types": "tsc --emitDeclarationOnly",
    "test": "bun test",
    "demo": "vite --config demo/vite.config.ts",
    "demo:build": "vite build --config demo/vite.config.ts"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.9",
    "@types/bun": "^1.3.11",
    "@types/react": "^19.2.14",
    "typescript": "^5",
    "vite": "^8.0.7"
  },
  "author": "Justin Moser",
  "license": "MIT",
  "keywords": ["viewport", "keyboard", "fixed", "header", "virtual-keyboard", "mobile", "ios", "safari"],
  "repository": {
    "type": "git",
    "url": "https://github.com/justinmoser/viewport-lock.git"
  },
  "homepage": "https://github.com/justinmoser/viewport-lock#readme",
  "bugs": {
    "url": "https://github.com/justinmoser/viewport-lock/issues"
  }
}
